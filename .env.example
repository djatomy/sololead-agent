# SoloLead Agent - 環境設定テンプレート
# このファイルを参考に .env ファイルを作成してください
# .env は .gitignore に含まれており、GitHubにアップロードされません

# AI API 設定
# 使用するAI: claude, gemini, または gpt4
VITE_AI_PROVIDER=claude

# Anthropic Claude API
# https://console.anthropic.com で取得
VITE_CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API
# https://makersuite.google.com/app/apikey で取得
VITE_GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI GPT-4 API
# https://platform.openai.com/api-keys で取得
VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Search API
# https://developers.google.com/custom-search で取得
VITE_GOOGLE_SEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GOOGLE_SEARCH_ENGINE_ID=xxxxxxxxxxxxxxxxxxxxx

# アプリケーション設定
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# 開発環境用
VITE_DEBUG_MODE=false
VITE_API_BASE_URL=http://localhost:3000
